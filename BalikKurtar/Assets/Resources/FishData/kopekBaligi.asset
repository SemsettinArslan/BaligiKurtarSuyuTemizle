  fishId: kopekBaligi
  displayName: "K\xF6pek Bal\u0131\u011F\u0131"
  scientificName: Selachimorpha
  habitat: "\"Okyanuslar, denizler ve baz\u0131 k\u0131y\u0131 b\xF6lgelerinde ya\u015Farlar.
    Genellikle s\u0131cak ve \u0131l\u0131man denizleri tercih ederler."
  diet: "Et\xE7ildir. Bal\u0131klar, m\xFCrekkep bal\u0131klar\u0131, deniz memelileri
    ve baz\u0131 t\xFCrlerde kabuklular ile beslenir."
  funFact: "K\xF6pek bal\u0131klar\u0131 y\xFCzy\u0131llard\u0131r y\u0131ld\u0131r
    neredeyse hi\xE7 de\u011Fi\u015Fmeden ya\u015Famlar\u0131n\u0131 s\xFCrd\xFCrmektedir.
    Baz\u0131 t\xFCrler 300\u2019den fazla di\u015Fe sahip olabilir."
  sizeInfo: "0.5 m \u2013 12 m"
